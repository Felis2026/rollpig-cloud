# ================================ 本地环境与敏感配置 ================================ #
# 真实部署参数只放在本地 `docker-compose.yml`，公开仓库中只提交 `docker-compose.yml.example`。
docker-compose.yml
.env
.env.*
static/
.deploy/

# ================================ Python 运行缓存 ================================ #
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# ================================ 证书与密钥 ================================ #
*.pem
*.key
*.crt
*.p12
*.pfx

# ================================ 本地迁移与备份数据 ================================ #
*.sql
*.sql.gz
*.dump
